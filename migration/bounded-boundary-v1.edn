{:schema "kotoba-atprotocol-migration/v1"
 :profile :atprotocol/bounded-boundary-v1
 :legacy {:boundary-source "src/atprotocol/boundary.cljc"
          :status :retained-general-oracle}
 :canonical {:engine-and-conformance "src/atprotocol/bounded_boundary.kotoba"}
 :domain
 {:functions [:owner :delegated?]
  :covers "the fixed 12-concern ADR-2607071500 responsibility-boundary
           table verbatim: handle-resolution/lexicon/record-codec/xrpc/
           repo-commit-wire/profile-view owned by :atprotocol,
           identity-keys/fact-truth/graph-cid/mutable-head/distribution/
           app-manifest delegated to :kotoba-protocol; unknown concerns
           resolve to :unknown (the legacy CLJC returns nil for the same
           case)"
  :value "a tamper-evident, capability-free, sovereign-source declaration
         of which system owns which architectural concern -- verified
         directly against atprotocol.atprotocol-test's
         boundary-splits-cleanly test before compiling"}
 :excluded [:atprotocol.projection :atprotocol.app-record :atprotocol.profile]
 :exclusion-reason "projection.cljc's codec contract validates function
                    values (fn? checks) -- not a Kotoba-representable
                    concept; app-record.cljc/profile.cljc both project
                    open-ended JSON-shaped maps via reduce-kv over
                    arbitrary keys (the same bounded-arbitrary-keyed-map
                    gap already found for kotoba-lang/search and
                    kotoba-lang/sheets) and depend on kotoba.protocol.app,
                    a sibling repo. Only boundary.cljc -- a fixed, closed
                    12-entry table with no external dependency -- is
                    independently portable."
 :compiler-findings
 {:equality-returns-i64-not-bool
  {:description "kotoba-lang/compiler's = operator (and other comparisons)
                 type as :i64, not :bool -- a :bool-declared function body
                 that returns a bare (= a b) expression fails the subset
                 gate with \"expression type mismatch: expected bool, got
                 i64\". Not a bug, just a gotcha: wrap in (if (= a b) true
                 false) to actually produce a :bool value. Not filed as an
                 issue since this behaves as designed once understood."}}
 :verification
 {:hand-verified-cases
  "all 12 boundary/owner entries plus the unknown-concern case
   (:unheard-of -> :unknown, matching the legacy nil-for-unknown
   contract) cross-checked directly against
   atprotocol.atprotocol-test/boundary-splits-cleanly's assertions
   before compiling -- not re-derived independently, since the legacy
   test *is* the ground truth for this fixed table"
  :web {:main 42 :required-capabilities []}
  :wasm {:main 42}
  :required-capabilities []
  :local-verification
  {:legacy-test-suite-note "clojure -M:test could not run in this
                            isolated review checkout (deps.edn's
                            :local/root sibling dependency on
                            kotoba-protocol is only resolvable inside
                            the west-managed monorepo); ground truth
                            was read directly from
                            atprotocol.atprotocol-test's source instead"
   :kotoba-compile [:js-browser :wasm32-browser]
   :kotoba-conformance :passed-both-targets}}
 :cutover {:bounded-profile-authorized true :general-cljc-oracle-retained true}}
